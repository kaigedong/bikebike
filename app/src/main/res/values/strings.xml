    <!-- Identity Guide -->
    <string name="how_to_get_identity">How to get the log file?</string>
    <string name="guide_step1">1. Enable Developer Options</string>
    <string name="guide_step1_desc">Settings → About Phone → Tap \"Build Number\" 7 times</string>
    <string name="guide_step2">2. Enable Bluetooth HCI Log</string>
    <string name="guide_step2_desc">Developer Options → Enable \"Bluetooth HCI Snoop Log\" → Restart Bluetooth</string>
    <string name="guide_step3">3. Connect bike via Keep App and ride</string>
    <string name="guide_step3_desc">Open Keep App → Connect bike → Ride 1–2 min → End session → Close Keep App</string>
    <string name="guide_step4">4. Import the log file</string>
    <string name="guide_step4_desc">Tap \"Import Log File\" above\nSelect btsnoop_hci.log\n(Path: /data/misc/bluetooth/logs/)\n\nIf inaccessible, use adb pull to export to Download folder first</string>
    <string name="guide_tips">💡 Tips</string>
    <string name="guide_tips_desc">• The bike must be disconnected from WiFi\n• You may need to re-extract after firmware updates\n• Also supports direct identity.json import (generated by BikeCon tool)</string>

